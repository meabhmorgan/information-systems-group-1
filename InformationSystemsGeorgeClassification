    "import numpy as np\n",
    "import pandas as pd\n",
    "from sklearn.linear_model import LinearRegression\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.metrics import r2_score, mean_squared_error, confusion_matrix, ConfusionMatrixDisplay\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "\n",
    "data = pd.read_csv(\"StudentPerformanceFactors.csv\")\n",
    "\n",
    "data = data.drop(columns=[\"Distance_from_Home\"], errors=\"ignore\")\n",
    "data[\"Teacher_Quality\"] = data[\"Teacher_Quality\"].fillna(data[\"Teacher_Quality\"].mode()[0])\n",
    "data[\"Parental_Education_Level\"] = data[\"Parental_Education_Level\"].fillna(data[\"Parental_Education_Level\"].mode()[0])\n",
    "\n",
    "cont_cols   = [col for col in data.select_dtypes(include='number').columns if col != 'Exam_Score']\n",
    "all_cat     = data.select_dtypes(include='object').columns.tolist()\n",
    "binary_cols = [col for col in all_cat if data[col].nunique() == 2]\n",
    "cat_cols    = [col for col in all_cat if data[col].nunique() > 2]\n",
    "\n",
    "for col in binary_cols:\n",
    "    cats = data[col].unique()\n",
    "    data[col] = data[col].map({cats[0]: 0, cats[1]: 1})\n",
    "\n",
    "\n",
    "data_encoded = pd.get_dummies(data, columns=cat_cols, drop_first=True)\n",
    "\n",
    "\n",
    "X = data_encoded.drop(columns=['Exam_Score'])\n",
    "y = data_encoded['Exam_Score'].values\n",
    "\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y, test_size=0.3, random_state=42\n",
    ")\n",
    "\n",
    "\n",
    "other_cols = [col for col in X.columns if col not in cont_cols]\n",
    "\n",
    "scaler = StandardScaler()\n",
    "X_train_scaled = pd.DataFrame(scaler.fit_transform(X_train[cont_cols]),\n",
    "                               columns=cont_cols, index=X_train.index)\n",
    "X_test_scaled  = pd.DataFrame(scaler.transform(X_test[cont_cols]),\n",
    "                               columns=cont_cols, index=X_test.index)\n",
    "\n",
    "X_train_final = pd.concat([X_train_scaled, X_train[other_cols]], axis=1)\n",
    "X_test_final  = pd.concat([X_test_scaled,  X_test[other_cols]],  axis=1)\n",
    "\n",
    "\n",
    "lr = LinearRegression()\n",
    "lr.fit(X_train_final, y_train)\n",
    "\n",
    "train_preds = lr.predict(X_train_final)\n",
    "test_preds  = lr.predict(X_test_final)\n",
    "\n",
    "\n",
    "def print_metrics(label, y_true, y_pred):\n",
    "    r2   = r2_score(y_true, y_pred)\n",
    "    rmse = np.sqrt(mean_squared_error(y_true, y_pred))\n",
    "    mae  = np.mean(np.abs(y_true - y_pred))\n",
    "    print(f\"\\n── {label} ─────────────────────────────────────────\")\n",
    "    print(f\"  R²:   {r2:.4f}\")\n",
    "    print(f\"  RMSE: {rmse:.4f}\")\n",
    "    print(f\"  MAE:  {mae:.4f}\")\n",
    "\n",
    "def grade_accuracy(y_true, y_pred):\n",
    "    bins       = [-1, 60, 69, 79, 89, 101]\n",
    "    grade_labels = ['F', 'D', 'C', 'B', 'A']\n",
    "    true_grades = pd.cut(y_true, bins=bins, labels=grade_labels)\n",
    "    pred_grades = pd.cut(y_pred, bins=bins, labels=grade_labels)\n",
    "    return np.mean(true_grades == pred_grades) * 100\n",
    "\n",
    "print_metrics(\"Full Model — Training\", y_train, train_preds)\n",
    "print_metrics(\"Full Model — Test\",     y_test,  test_preds)\n",
    "print(f\"\\n  Train Grade Accuracy: {grade_accuracy(y_train, train_preds):.2f}%\")\n",
    "print(f\"  Test  Grade Accuracy: {grade_accuracy(y_test,  test_preds):.2f}%\")\n",
    "\n",
    "\n",
    "importance_df = pd.DataFrame({\n",
    "    'Feature':     X_train_final.columns.tolist(),\n",
    "    'Coefficient': lr.coef_\n",
    "}).assign(Abs_Coefficient=lambda df: df['Coefficient'].abs()) \\\n",
    "  .sort_values('Abs_Coefficient', ascending=False).reset_index(drop=True)\n",
    "\n",
    "print(f\"\\n── Feature Importance (sorted by |coefficient|) ──────\")\n",
    "print(importance_df[['Feature', 'Coefficient']].to_string(index=False))\n",
    "\n",
    "\n",
    "THRESHOLD = 1.07\n",
    "\n",
    "selected_features = importance_df[importance_df['Abs_Coefficient'] > THRESHOLD]['Feature'].tolist()\n",
    "\n",
    "print(f\"\\n── Features Above ±{THRESHOLD} Threshold ─────────────────────\")\n",
    "print(f\"  Count : {len(selected_features)}\")\n",
    "for feat in selected_features:\n",
    "    coef = importance_df.loc[importance_df['Feature'] == feat, 'Coefficient'].values[0]\n",
    "    print(f\"  {feat:<45} {coef:+.4f}\")\n",
    "\n",
    "\n",
    "lr_final = LinearRegression()\n",
    "lr_final.fit(X_train_final[selected_features], y_train)\n",
    "\n",
    "train_preds_final = lr_final.predict(X_train_final[selected_features])\n",
    "test_preds_final  = lr_final.predict(X_test_final[selected_features])\n",
    "\n",
    "print_metrics(\"Threshold Model — Training\", y_train, train_preds_final)\n",
    "print_metrics(\"Threshold Model — Test\",     y_test,  test_preds_final)\n",
    "print(f\"\\n  Train Grade Accuracy: {grade_accuracy(y_train, train_preds_final):.2f}%\")\n",
    "print(f\"  Test  Grade Accuracy: {grade_accuracy(y_test,  test_preds_final):.2f}%\")\n",
    "\n",
    "\n",
    "colors = ['steelblue' if c >= 0 else 'coral' for c in importance_df['Coefficient']]\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.barh(importance_df['Feature'], importance_df['Coefficient'], color=colors)\n",
    "plt.axvline(0,           color='black',    linewidth=0.8)\n",
    "plt.axvline( THRESHOLD,  color='seagreen', linestyle='--', linewidth=1.5,\n",
    "             label=f'Threshold ±{THRESHOLD}')\n",
    "plt.axvline(-THRESHOLD,  color='seagreen', linestyle='--', linewidth=1.5)\n",
    "plt.xlabel('Standardised Coefficient')\n",
    "plt.title('Feature Importance — Linear Regression')\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"feature_importance.png\", dpi=150)\n",
    "plt.show()\n",
    "\n",
    "\n",
    "plt.figure(figsize=(6, 5))\n",
    "plt.scatter(y_test, test_preds_final, alpha=0.5, color='steelblue', edgecolors='none')\n",
    "plt.plot([y.min(), y.max()], [y.min(), y.max()], 'r--', linewidth=1, label='Perfect fit')\n",
    "plt.xlabel('Actual Exam Score')\n",
    "plt.ylabel('Predicted Exam Score')\n",
    "plt.title(f'Predicted vs Actual — Threshold Model ({len(selected_features)} features)')\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"predicted_vs_actual.png\", dpi=150)\n",
    "plt.show()\n",
    "\n",
    "\n",
    "bins         = [-1, 60, 69, 79, 89, 101]\n",
    "grade_labels = ['F', 'D', 'C', 'B', 'A']\n",
    "\n",
    "true_grades = pd.cut(y_test,           bins=bins, labels=grade_labels).astype(str)\n",
    "pred_grades = pd.cut(test_preds_final, bins=bins, labels=grade_labels).astype(str)\n",
    "\n",
    "cm = confusion_matrix(true_grades, pred_grades, labels=grade_labels)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 6))\n",
    "disp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=grade_labels)\n",
    "disp.plot(ax=ax, cmap='Blues', values_format='d')\n",
    "\n",
    "ax.set_title('Confusion Matrix — Grade Bands (Test Set)')\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"confusion_matrix.png\", dpi=150)\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n── Confusion Matrix Metrics ─────────────────────────────────────────\")\n",
    "\n",
    "\n",
    "for i, grade in enumerate(grade_labels):\n",
    "    TP = cm[i, i]\n",
    "    FP = cm[:, i].sum() - TP\n",
    "    FN = cm[i, :].sum() - TP\n",
    "    TN = cm.sum() - TP - FP - FN\n",
    "\n",
    "    TPR = TP / (TP + FN) if (TP + FN) > 0 else 0 \n",
    "    TNR = TN / (TN + FP) if (TN + FP) > 0 else 0  \n",
    "    FPR = FP / (FP + TN) if (FP + TN) > 0 else 0  \n",
    "    precision = TP / (TP + FP) if (TP + FP) > 0 else 0\n",
    "    f1 = 2 * (precision * TPR) / (precision + TPR) if (precision + TPR) > 0 else 0\n",
    "\n",
    "    print(f\"\\n  Grade {grade}:\")\n",
    "    print(f\"    TP: {TP}  FP: {FP}  FN: {FN}  TN: {TN}\")\n",
    "    print(f\"    TPR (Recall):    {TPR:.4f}\")\n",
    "    print(f\"    TNR (Specificity): {TNR:.4f}\")\n",
    "    print(f\"    FPR:             {FPR:.4f}\")\n",
    "    print(f\"    Precision:       {precision:.4f}\")\n",
    "    print(f\"    F1 Score:        {f1:.4f}\")\n",
    "\n",
    "# Overall metrics\n",
    "overall_accuracy = cm.diagonal().sum() / cm.sum()\n",
    "macro_tpr        = np.mean([cm[i, i] / cm[i, :].sum() for i in range(len(grade_labels)) if cm[i, :].sum() > 0])\n",
    "\n",
    "print(f\"\\n  Overall Accuracy:  {overall_accuracy:.4f}\")\n",
    "print(f\"  Macro Avg TPR:     {macro_tpr:.4f}\")"
