    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "data_ig = pd.read_csv(\"StudentPerformanceFactors.csv\").dropna(axis=1, how='all')\n",
    "data_ig = data_ig.drop(columns=[\"Distance_from_Home\"], errors=\"ignore\")\n",
    "data_ig[\"Teacher_Quality\"] = data_ig[\"Teacher_Quality\"].fillna(data_ig[\"Teacher_Quality\"].mode()[0])\n",
    "data_ig[\"Parental_Education_Level\"] = data_ig[\"Parental_Education_Level\"].fillna(data_ig[\"Parental_Education_Level\"].mode()[0])\n",
    "\n",
    "data_ig['Grade'] = pd.cut(data_ig['Exam_Score'],\n",
    "                           bins=[0, 60, 69, 79, 89, 100],\n",
    "                           labels=['F', 'D', 'C', 'B', 'A'])\n",
    "data_ig['Hours_Studied'] = pd.cut(data_ig['Hours_Studied'],\n",
    "                                   bins=[0, 10, 20, 30, 44],\n",
    "                                   labels=['Low', 'Medium', 'High', 'Very High'])\n",
    "\n",
    "data_ig['Attendance'] = pd.cut(data_ig['Attendance'],\n",
    "                                bins=[0, 59, 74, 89, 100],\n",
    "                                labels=['Poor', 'Average', 'Good', 'Excellent'])\n",
    "\n",
    "data_ig['Sleep_Hours'] = pd.cut(data_ig['Sleep_Hours'],\n",
    "                                 bins=[0, 5, 7, 9, 12],\n",
    "                                 labels=['Poor', 'Fair', 'Good', 'Oversleep'])\n",
    "\n",
    "data_ig['Previous_Scores'] = pd.cut(data_ig['Previous_Scores'],\n",
    "                                     bins=[0, 60, 69, 79, 89, 100],\n",
    "                                     labels=['F', 'D', 'C', 'B', 'A'])\n",
    "\n",
    "data_ig['Tutoring_Sessions'] = pd.cut(data_ig['Tutoring_Sessions'],\n",
    "                                       bins=[-1, 0, 2, 4, 8],\n",
    "                                       labels=['None', 'Low', 'Medium', 'High'])\n",
    "\n",
    "data_ig['Physical_Activity'] = pd.cut(data_ig['Physical_Activity'],\n",
    "                                       bins=[-1, 1, 3, 5, 7],\n",
    "                                       labels=['None', 'Low', 'Medium', 'High'])\n",
    "\n",
    "# Convert remaining object columns to category\n",
    "for col in data_ig.select_dtypes(include='object').columns:\n",
    "    data_ig[col] = data_ig[col].astype('category')\n",
    "\n",
    "\n",
    "def entropy(series):\n",
    "    probs = series.value_counts(normalize=True)\n",
    "    probs = probs[probs > 0]\n",
    "    return -np.sum(probs * np.log2(probs))\n",
    "\n",
    "\n",
    "def information_gain(data, feature, target='Grade'):\n",
    "    data = data[[feature, target]].dropna()          # drop NaN in either column\n",
    "    parent_entropy = entropy(data[target])\n",
    "    weighted_entropy = 0\n",
    "    for val in data[feature].unique():\n",
    "        subset = data[data[feature] == val][target]\n",
    "        weighted_entropy += (len(subset) / len(data)) * entropy(subset)\n",
    "    return parent_entropy - weighted_entropy\n",
    "\n",
    "\n",
    "print(f\"Entropy of Exam_Score (Grade): {entropy(data_ig['Grade']):.4f}\")\n",
    "print(\"\\nGrade Distribution:\")\n",
    "print(data_ig['Grade'].value_counts().sort_index())\n",
    "\n",
    "\n",
    "features = [col for col in data_ig.columns if col not in ['Exam_Score', 'Grade']]\n",
    "\n",
    "ig_results = [{'Feature': feat, 'Information Gain': round(information_gain(data_ig, feat), 4)}\n",
    "              for feat in features]\n",
    "\n",
    "ig_entropy = [{'Feature': feat, 'Entropy': round(entropy(data_ig[feat]), 4)}\n",
    "              for feat in features]\n",
    "\n",
    "entropy_table = pd.DataFrame(ig_entropy).sort_values('Entropy', ascending=False).reset_index(drop=True)\n",
    "entropy_table.index += 1\n",
    "ig_table = pd.DataFrame(ig_results).sort_values('Information Gain', ascending=False).reset_index(drop=True)\n",
    "ig_table.index += 1\n",
    "\n",
    "print(\"\\nEntropy Table:\")\n",
    "print(entropy_table.to_string())\n",
    "print(\"\\nInformation Gain Table:\")\n",
    "print(ig_table.to_string())"
   ]
